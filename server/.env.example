# DeepSeek API Key (required)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# GitHub Personal Access Token (optional, needed for github_* tools)
# Create one at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos only)
GITHUB_TOKEN=your_github_pat_here

# Allowed root paths for file system access (comma-separated)
# ALLOWED_ROOT_PATHS=/home/user/projects,/tmp/workspace

# CORS origin (default: http://localhost:5173)
# CORS_ORIGIN=http://localhost:5173

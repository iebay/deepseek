# DeepSeek API Key（必填）从 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 地址（不需要 /v1 后缀，SDK 会自动添加）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 后端服务端口
SERVER_PORT=3001

# 允许访问的根目录（安全限制，多个目录用逗号分隔；不设置时默认为用户 home 目录）
# 示例（Linux/macOS）: ALLOWED_ROOT_PATHS=/home/user/projects,/home/user/work
# 示例（Windows）:    ALLOWED_ROOT_PATHS=C:/Users/YourName/projects
ALLOWED_ROOT_PATHS=/path/to/your/projects

# CORS 允许的前端地址
CORS_ORIGIN=http://localhost:5173
